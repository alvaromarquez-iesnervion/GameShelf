# GameShelf — Variables de entorno
# Copiar este archivo como .env y rellenar los valores reales.
# .env nunca se sube a git (está en .gitignore).
# El prefijo EXPO_PUBLIC_ expone la variable al cliente (bundle de la app).

# ─── GameShelf API ─────────────────────────────────────────────────────────────
# URL base del backend FastAPI. Sin trailing slash.
# Desarrollo local: http://localhost:8000
# Producción: URL de tu servidor o túnel ngrok
EXPO_PUBLIC_GAMESHELF_API_URL=http://localhost:8000

# ─── Firebase ──────────────────────────────────────────────────────────────────
# Crear proyecto en https://console.firebase.google.com
# Project settings → General → Your apps → Add app (Web) → Copiar config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
